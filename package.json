{
  "name": "diagview",
  "version": "1.0.5",
  "description": "A lightweight framework-agnostic viewer for SVG diagrams (Mermaid, Graphviz, etc). Adds interactive Zoom, Pan, Search, Export, and Presentation Mode.",
  "type": "module",
  "main": "dist/diagview.umd.js",
  "module": "dist/esm/index.js",
  "unpkg": "dist/diagview.umd.min.js",
  "jsdelivr": "dist/diagview.umd.min.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/diagview.umd.js"
    },
    "./style": {
      "types": "./dist/diagview.css",
      "import": "./dist/diagview.css",
      "require": "./dist/diagview.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "dev": "rollup -c -w",
    "build": "npm run version:sync && npm run clean && npm run build:lib && npm run build:types",
    "build:lib": "rollup -c",
    "build:analyze": "npm run clean && ANALYZE=1 rollup -c && npm run build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "version:sync": "node scripts/sync-version.js",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "size": "size-limit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "release": "release-it",
    "prepare": "husky"
  },
  "keywords": [
    "diagram",
    "svg",
    "viewer",
    "zoom",
    "pan",
    "export",
    "interactive",
    "visualization",
    "flowchart",
    "chart",
    "mermaid",
    "d3",
    "graphviz",
    "plantuml",
    "framework-agnostic"
  ],
  "author": "Khadirullah Mohammad <94954931+khadirullah@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/khadirullah/diagview.git"
  },
  "bugs": {
    "url": "https://github.com/khadirullah/diagview/issues"
  },
  "homepage": "https://github.com/khadirullah/diagview#readme",
  "peerDependencies": {
    "@panzoom/panzoom": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^46.9.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.1.0",
    "release-it": "^20.0.1",
    "rollup": "^4.57.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^11.0.0",
    "typescript": "^5.7.3"
  },
  "size-limit": [
    {
      "name": "UMD bundle (script tag)",
      "path": "dist/diagview.umd.min.js",
      "limit": "32 KB"
    },
    {
      "name": "ESM bundle (bundlers)",
      "path": "dist/esm/index.js",
      "limit": "36 KB"
    }
  ],
  "engines": {
    "node": ">=20.17.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "globals": {
      "__DV_VERSION__": "1.0.5"
    },
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "moduleNameMapper": {
      "\\.css$": "<rootDir>/tests/mocks/styleMock.js"
    },
    "transform": {},
    "coverageThreshold": {
      "global": {
        "statements": 53,
        "lines": 53,
        "functions": 48,
        "branches": 38
      }
    }
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.js": [
      "prettier --write"
    ],
    "*.{json,md,css,yml}": [
      "prettier --write"
    ]
  }
}
